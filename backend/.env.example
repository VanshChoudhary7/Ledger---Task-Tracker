# MongoDB connection string (MongoDB Atlas or local)
# Local example:   mongodb://127.0.0.1:27017/task-tracker
# Atlas example:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/task-tracker
MONGO_URI=mongodb://127.0.0.1:27017/task-tracker

# Port the API server listens on
PORT=5000

# Comma-separated list of origins allowed to call this API (your deployed frontend URL)
CLIENT_ORIGIN=http://localhost:5173
